{
  "manifest_version": 3,
  "name": "Betway RAG Assistant",
  "version": "1.0.0",
  "description": "AI-powered guide for Betway sites across all regions — powered by your local RAG chatbot.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://*.betway.co.za/*",
    "https://*.betway.com.gh/*",
    "https://*.betway.co.tz/*",
    "https://*.betway.com.ng/*",
    "https://*.betway.co.zm/*",
    "https://*.betway.co.mz/*",
    "https://*.betway.co.mw/*",
    "https://*.betway.co.bw/*",
    "https://*.betway.com/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.betway.co.za/*",
        "https://*.betway.com.gh/*",
        "https://*.betway.co.tz/*",
        "https://*.betway.com.ng/*",
        "https://*.betway.co.zm/*",
        "https://*.betway.co.mz/*",
        "https://*.betway.co.mw/*",
        "https://*.betway.co.bw/*",
        "https://*.betway.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}